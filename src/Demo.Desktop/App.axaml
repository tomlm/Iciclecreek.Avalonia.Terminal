<Application xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:console="https://github.com/jinek/consolonia"
			 xmlns:wm="using:Consolonia.ManagedWindows"
			 xmlns:demo="clr-namespace:Demo.Views;assembly=Demo"
			 x:Class="Demo.Desktop.App"
			 RequestedThemeVariant="Default">
	<Application.Styles>
		<FluentTheme />
		<Style Selector="demo|ManagedTerminalWindow">
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="Background" Value="Black"/>
			<Setter Property="FontFamily" Value="fonts:CascadiaCode#Cascadia Code"/>
			<Setter Property="FontSize" Value="14"/>
		</Style >
	</Application.Styles>

</Application>